FRONTEND_URL=http://localhost:4200

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/oauth/google/callback
MAPBOX_PUBLIC_TOKEN=
REVIEW_EDIT_WINDOW_DAYS=7
PAYMENT_DEFAULT_PROVIDER=simulator
PAYMENT_ENABLED_PROVIDERS=simulator,mercadopago,paypal
PAYMENT_SIMULATOR_ENABLED=true
PAYMENTS_CURRENCY=UYU
PAYMENT_INTENT_EXPIRATION_MINUTES=30

# Mercado Pago
# Valores validos:
# sandbox    => usa sandbox_init_point si Mercado Pago lo devuelve.
# production => usa init_point.
#
# No inferir el modo por el prefijo de la credencial. Las credenciales de
# prueba tambien pueden comenzar con APP_USR-.
MERCADOPAGO_MODE=sandbox
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=

# Secret legacy/default. Se mantiene por compatibilidad.
MERCADOPAGO_WEBHOOK_SECRET=

# Secrets explicitos de Webhooks > Modo de prueba / Modo productivo.
# Configurar ambos cuando Mercado Pago entregue firmas distintas por modo.
MERCADOPAGO_WEBHOOK_SECRET_TEST=
MERCADOPAGO_WEBHOOK_SECRET_PRODUCTION=

MERCADOPAGO_SUCCESS_URL=http://localhost:4200/payments/success
MERCADOPAGO_FAILURE_URL=http://localhost:4200/payments/failure
MERCADOPAGO_PENDING_URL=http://localhost:4200/payments/pending

# En local usar ngrok o Cloudflare Tunnel, nunca localhost.
MERCADOPAGO_NOTIFICATION_URL=https://example.ngrok-free.app/api/v1/payments/webhooks/mercadopago
MERCADOPAGO_WEBHOOK_SIGNATURE_REQUIRED=true
MERCADOPAGO_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_CURRENCY=USD
PAYPAL_EXCHANGE_RATES='{"UYU":40}'
PAYPAL_SUCCESS_URL=http://localhost:4200/payments/success
PAYPAL_CANCEL_URL=http://localhost:4200/payments/cancel

VIDEO_PROVIDER=simulator
VIDEO_JOIN_BEFORE_MINUTES=15
VIDEO_JOIN_AFTER_MINUTES=120
VIDEO_SIMULATOR_BASE_URL=http://localhost:4200/video

LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=BLMEod61f44duKPvt9PYuWEXQmGAhb4s9HjGcz5nGiWSwJ96hTrLXpytqAMCeKG6
LIVEKIT_API_SECRET=r9ZP6uROa1pWeqABtt9xTtoXtBMgZoG2HoTauMr9Om23aW6cTOupP3wf2XoFlfOr
LIVEKIT_TOKEN_TTL_SECONDS=3600
SEED_DEMO_DATA=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
